{
  "name": "power-write-new-ver",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "prebuild": "node scripts/update-sw-version.js",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "db:generate": "dotenv -e .env.local -- drizzle-kit generate",
    "db:migrate": "dotenv -e .env.local -- tsx scripts/db-migrate.ts",
    "db:migrate:apply": "dotenv -e .env.local -- tsx scripts/db-migrate.ts --confirm",
    "db:migrate:backfill": "dotenv -e .env.local -- tsx scripts/backfill-drizzle-journal.ts",
    "db:migrate:backfill:dry": "dotenv -e .env.local -- tsx scripts/backfill-drizzle-journal.ts --dry-run",
    "db:migrate:verify": "dotenv -e .env.local -- tsx scripts/verify-migrate-noop.ts",
    "db:verify-pool": "dotenv -e .env.local -- tsx scripts/verify-pool-driver.ts",
    "db:verify-library": "dotenv -e .env.local -- tsx scripts/verify-library-loader.ts",
    "db:verify-book-detail": "dotenv -e .env.local -- tsx scripts/verify-book-detail-loader.ts",
    "db:push": "dotenv -e .env.local -- drizzle-kit push",
    "db:studio": "dotenv -e .env.local -- drizzle-kit studio",
    "pwa:clear-cache": "echo 'Open browser DevTools > Application > Storage > Clear site data'",
    "pwa:update": "node scripts/update-sw-version.js",
    "worker": "dotenv -e .env.local -- tsx scripts/start-worker.ts",
    "worker:dev": "dotenv -e .env.local -- tsx watch scripts/start-worker.ts",
    "queue:verify": "dotenv -e .env.local -- tsx scripts/verify-queue.ts"
  },
  "dependencies": {
    "@ai-sdk/openai": "^2.0.56",
    "@clerk/nextjs": "^6.39.2",
    "@fontsource/crimson-pro": "^5.2.8",
    "@fontsource/eb-garamond": "^5.2.7",
    "@fontsource/lora": "^5.2.8",
    "@neondatabase/serverless": "^1.0.2",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-toast": "^1.2.15",
    "@react-pdf/renderer": "^4.3.1",
    "@sparticuz/chromium": "^143.0.0",
    "@vercel/blob": "^2.0.0",
    "@vercel/edge-config": "^1.4.3",
    "ai": "^5.0.81",
    "bufferutil": "^4.0.9",
    "bullmq": "^5.74.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "docx": "^9.5.1",
    "dotenv": "^17.2.3",
    "drizzle-orm": "^0.44.7",
    "drizzle-zod": "^0.8.3",
    "epub-gen-memory": "^1.1.2",
    "framer-motion": "^12.23.24",
    "idb": "^8.0.0",
    "ioredis": "^5.10.1",
    "jspdf": "^3.0.3",
    "jszip": "^3.10.1",
    "lodash": "^4.17.21",
    "lucide-react": "^0.548.0",
    "mammoth": "^1.11.0",
    "next": "^16.2.4",
    "next-themes": "^0.4.6",
    "pagedjs": "^0.4.3",
    "pdf-parse": "^2.4.5",
    "pdfkit": "^0.17.2",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "puppeteer": "^24.32.0",
    "puppeteer-core": "^24.32.1",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "tailwind-merge": "^3.3.1",
    "utf-8-validate": "^6.0.5",
    "uuid": "^13.0.0",
    "ws": "^8.18.3",
    "zod": "^4.1.12",
    "zustand": "^5.0.8"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/lodash": "^4.17.20",
    "@types/node": "^20",
    "@types/pdfkit": "^0.17.3",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/uuid": "^10.0.0",
    "@types/ws": "^8.18.1",
    "dotenv-cli": "^11.0.0",
    "drizzle-kit": "^0.31.6",
    "eslint": "^9",
    "eslint-config-next": "16.0.0",
    "tailwindcss": "^4",
    "tsx": "^4.20.6",
    "typescript": "^5"
  }
}
